# Dependencies
node_modules/

# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test & coverage artifacts
.tap/
.nyc_output/
coverage/

# Chrome Web Store packaging / signing (keep these OUT of git)
# *.pem  — extension private key (a secret, used to sign .crx uploads)
# *.crx  — packed extension (built artifact, regenerable)
# *.zip  — store upload archive (built artifact, regenerable)
*.pem
*.crx
*.zip

# Local dev scratch files
tmp/
scratch/
.*.swp

# Editor / IDE
.vscode/
.idea/
*.iml
